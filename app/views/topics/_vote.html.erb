<% voted = voted_by?(topic, user) %>
<div class="vote__box">
  <% if user %>
    <% if voted %>
      <%= button_to "▲", remove_upvote_topic_path(topic), method: :delete,
            form: { data: { turbo_stream: true } }, class: "vote__btn vote__btn--on", "aria-label": "Remove upvote" %>
    <% else %>
      <%= button_to "▲", upvote_topic_path(topic), method: :post,
            form: { data: { turbo_stream: true } }, class: "vote__btn", "aria-label": "Upvote" %>
    <% end %>
  <% else %>
    <span class="vote__btn vote__btn--disabled" title="Sign in to vote">▲</span>
  <% end %>
  <span class="vote__count"><%= topic.upvotes_count %></span>
</div>
